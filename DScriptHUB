local DroppedItems = workspace:WaitForChild("DroppedItems")

local function ProsesSikatItem(item)
    local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart") or item.PrimaryPart
    if not targetPart then return end
    
    -- VALIDASI TOTAL BERDASARKAN GAMBAR WORKSPACE (image_3a7d1d.png)
    local namaAsli = item.Name
    
    -- Filter Kasta Event: Jika nama foldernya murni tepat "Gold" atau "Rainbow"
    local IsEventSeed = (namaAsli == "Gold") or (namaAsli == "Rainbow")
    
    -- Eksekusi penyaringan saklar toggle config
    if IsEventSeed and not Config.AutoSeedEvent then return end 
    if not IsEventSeed and not Config.AutoNormalSeed then return end 
    
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    
    if root then
        StatusLabel.Text = IsEventSeed and "Status: SNIPING EVENT SEED! 🔥" or "Status: SNIPING NORMAL SEED"
        StatusLabel.TextColor3 = IsEventSeed and Color3.fromRGB(255, 140, 0) or Color3.fromRGB(241, 196, 15)
        
        -- Eksekusi Teleportasi
        root.CFrame = targetPart.CFrame * CFrame.new(0, 1, 0)
        
        -- Jeda aman penyesuaian kordinat
        task.wait(IsEventSeed and 0.15 or 0.08)
        
        -- Ambil item
        AmbilPromptInstan(item)
        
        task.wait(0.05)
        StatusLabel.Text = "Status: SNIPING ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(46, 204, 113)
    end
end

-- Scan item awal server
for _, item in ipairs(DroppedItems:GetChildren()) do ProsesSikatItem(item) end

-- Pengintai Real-time
DroppedItems.ChildAdded:Connect(function(newItem)
    task.wait(0.02)
    ProsesSikatItem(newItem)
end)
