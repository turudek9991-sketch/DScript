-- Fungsi untuk mendaftarkan tracker pemantauan instan pada suatu folder
local function DaftarkanPemantauFolder(folderObj)
    -- Ambil item yang sudah stand-by duluan di dalam folder saat script di-execute
    for _, item in ipairs(folderObj:GetChildren()) do 
        task.spawn(ProsesSikatItem, item) 
    end
    
    -- Pantau kedatangan item baru secara realtime (0 DELAY MURNI)
    folderObj.ChildAdded:Connect(function(newItem)
        task.spawn(ProsesSikatItem, newItem)
    end)
end

