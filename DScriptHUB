-- ============================================================
-- [SPEED PROFILES] Semua delay dikontrol dari sini
-- ============================================================
-- TeleportWait : jeda setelah teleport sebelum fire prompt
-- PromptRetry  : jeda antara retry fire prompt
-- ChildWait    : jeda saat ChildAdded sebelum proses
-- PromptWait   : max tunggu prompt muncul (detik)
local SpeedProfiles = {
    [1] = { name = "SAFE",    color = Color3.fromRGB(52, 152, 219),  TeleportWait = 0.12, PromptRetry = 0.08, ChildWait = 0.05, PromptWait = 1.0  },
    [2] = { name = "FAST",    color = Color3.fromRGB(46, 204, 113),  TeleportWait = 0.06, PromptRetry = 0.04, ChildWait = 0.02, PromptWait = 0.5  },
    [3] = { name = "TURBO",   color = Color3.fromRGB(241, 196, 15),  TeleportWait = 0.02, PromptRetry = 0.01, ChildWait = 0.01, PromptWait = 0.3  },
    [4] = { name = "INSTANT", color = Color3.fromRGB(231, 76, 60),   TeleportWait = 0,    PromptRetry = 0,    ChildWait = 0,    PromptWait = 0.1  },
}

local function GetSpeed()
    return SpeedProfiles[Config.SpeedMode] or SpeedProfiles[2]
end

local function LoadConfig()
    if isfile and readfile and isfile(ConfigFile) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigFile)) end)
        if ok and type(data) == "table" then
            if data.AutoNormalSeed ~= nil then Config.AutoNormalSeed = data.AutoNormalSeed end
            if data.AutoSeedEvent  ~= nil then Config.AutoSeedEvent  = data.AutoSeedEvent  end
            if data.SpeedMode      ~= nil then Config.SpeedMode      = data.SpeedMode      end
        end
    end
end

local function SaveConfig()
    if writefile then pcall(function() writefile(ConfigFile, HttpService:JSONEncode(Config)) end) end
end

