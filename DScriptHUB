local function AddSlider(parent, labelText, minVal, maxVal, defaultVal, callback)
    minVal     = minVal or 0
    maxVal     = maxVal or 100
    defaultVal = math.clamp(defaultVal or minVal, minVal, maxVal)
    local value = defaultVal

    local wrapper = Instance.new("Frame")
    wrapper.Size             = UDim2.new(1, 0, 0, 54)
    wrapper.BackgroundColor3 = CONFIG.BgItem
    wrapper.BorderSizePixel  = 0
    wrapper.ZIndex           = 8
    wrapper.Parent           = parent
    Instance.new("UICorner", wrapper).CornerRadius = UDim.new(0, 7)

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1, -64, 0, 22)
    lbl.Position           = UDim2.new(0, 14, 0, 6)
    lbl.BackgroundTransparency = 1
    lbl.Text               = labelText
    lbl.TextColor3         = CONFIG.TextPrimary
    lbl.TextSize           = 12
    lbl.Font               = Enum.Font.Gotham
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.ZIndex             = 9
    lbl.Parent             = wrapper

    local valLbl = Instance.new("TextLabel")
    valLbl.Size               = UDim2.new(0, 50, 0, 22)
    valLbl.Position           = UDim2.new(1, -60, 0, 6)
    valLbl.BackgroundTransparency = 1
    valLbl.Text               = tostring(defaultVal)
    valLbl.TextColor3         = CONFIG.AccentColor
    valLbl.TextSize           = 12
    valLbl.Font               = Enum.Font.GothamBold
    valLbl.TextXAlignment     = Enum.TextXAlignment.Right
    valLbl.ZIndex             = 9
    valLbl.Parent             = wrapper

    local track = Instance.new("Frame")
    track.Size             = UDim2.new(1, -28, 0, 4)
    track.Position         = UDim2.new(0, 14, 0, 36)
    track.BackgroundColor3 = CONFIG.SliderTrack
    track.BorderSizePixel  = 0
    track.ZIndex           = 9
    track.Parent           = wrapper
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local ratio0 = (defaultVal - minVal) / (maxVal - minVal)
    local fill = Instance.new("Frame")
    fill.Size             = UDim2.new(ratio0, 0, 1, 0)
    fill.BackgroundColor3 = CONFIG.AccentColor
    fill.BorderSizePixel  = 0
    fill.ZIndex           = 10
    fill.Parent           = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local hitbox = Instance.new("TextButton")
    hitbox.Size               = UDim2.new(1, 0, 0, 22)
    hitbox.Position           = UDim2.new(0, 0, 0, 28)
    hitbox.BackgroundTransparency = 1
    hitbox.Text               = ""
    hitbox.ZIndex             = 11
    hitbox.Parent             = wrapper

    local dragging = false
    hitbox.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    RunService.Heartbeat:Connect(function()
        if not dragging then return end
        local mX    = UserInputService:GetMouseLocation().X
        local aPos  = track.AbsolutePosition.X
        local aSize = track.AbsoluteSize.X
        local r     = math.clamp((mX - aPos) / aSize, 0, 1)
        value       = math.floor(minVal + r * (maxVal - minVal))
        fill.Size   = UDim2.new(r, 0, 1, 0)
        valLbl.Text = tostring(value)
        if callback then callback(value) end
    end)
    return wrapper
end

-- ============================================================
-- TAB SYSTEM
-- ============================================================
local TabPages   = {}
local TabButtons = {}
local ActiveTab  = nil

local function SwitchTab(tabName)
    for name, page in pairs(TabPages) do
        page.Visible = (name == tabName)
    end
    for name, btn in pairs(TabButtons) do
        if name == tabName then
            btn.BackgroundTransparency = 0
            btn.BackgroundColor3       = CONFIG.BgTabActive
            btn.TextColor3             = CONFIG.TextPrimary
        else
            btn.BackgroundTransparency = 1
            btn.TextColor3             = CONFIG.TextSecondary
        end
    end
    ActiveTab = tabName
end

for i, tab in ipairs(TABS) do
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size                = UDim2.new(1, 0, 0, 34)
    tabBtn.BackgroundTransparency = 1
    tabBtn.BackgroundColor3    = CONFIG.BgTabActive
    tabBtn.BorderSizePixel     = 0
    tabBtn.Text                = string.format("  %s  %s", tab.Icon, tab.Name)
    tabBtn.TextColor3          = CONFIG.TextSecondary
    tabBtn.TextSize            = 12
    tabBtn.Font                = Enum.Font.Gotham
    tabBtn.TextXAlignment      = Enum.TextXAlignment.Left
    tabBtn.LayoutOrder         = i
    tabBtn.ZIndex              = 8
    tabBtn.Parent              = TabList
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 6)

    local page = MakeContentFrame()
    TabPages[tab.Name]   = page
    TabButtons[tab.Name] = tabBtn

    tabBtn.MouseButton1Click:Connect(function()
        SwitchTab(tab.Name)
    end)
    tabBtn.MouseEnter:Connect(function()
        if ActiveTab ~= tab.Name then
            tabBtn.BackgroundTransparency = 0
            tabBtn.BackgroundColor3       = Color3.fromRGB(28, 28, 35)
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if ActiveTab ~= tab.Name then
            tabBtn.BackgroundTransparency = 1
        end
    end)
end

SwitchTab(TABS[1].Name)

