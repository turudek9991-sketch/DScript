-- ============================================================
-- IMPLEMENTASI TAB: TELEPORT (WITH FULL REFIX FLY MECHANIC)
-- ============================================================
do
    local p = TabPages["Teleport"]
    
    local FlyState = {
        Active = false,
        Speed = 50,
        ControlState = {W = 0, S = 0, A = 0, D = 0, Up = 0, Down = 0}
    }
    
    local Camera = workspace.CurrentCamera
    local FlyConnection
    
    local function StartFlying()
        local Character = LocalPlayer.Character
        if not Character then return end
        local Root = Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Root or not Humanoid then return end
        
        Humanoid.PlatformStand = true
        
        local BV = Instance.new("BodyVelocity")
        BV.Name = "DScript_FlyBV"
        BV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        BV.Velocity = Vector3.new(0, 0, 0)
        BV.Parent = Root
        
        local BG = Instance.new("BodyGyro")
        BG.Name = "DScript_FlyBG"
        BG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        BG.CFrame = Root.CFrame
        BG.Parent = Root
        
        FlyConnection = RunService.RenderStepped:Connect(function()
            if not Root or not Root.Parent or not FlyState.Active then return end
            BG.CFrame = Camera.CFrame
            
            local DriveVector = Vector3.new(
                FlyState.ControlState.A + FlyState.ControlState.D, 
                FlyState.ControlState.Up + FlyState.ControlState.Down, 
                FlyState.ControlState.W + FlyState.ControlState.S
            )
            
            if DriveVector.Magnitude > 0 then
                local CameraCFrame = Camera.CFrame
                -- FIX: Tanda minus (-) pada LookVector membalikkan arah sumbu Z agar W = Maju, S = Mundur
                local MoveDirection = (CameraCFrame.RightVector * DriveVector.X) 
                                    + (CameraCFrame.UpVector * DriveVector.Y) 
                                    + (CameraCFrame.LookVector * (-DriveVector.Z))
                
                BV.Velocity = MoveDirection.Unit * FlyState.Speed
            else
                BV.Velocity = Vector3.new(0, 0, 0)
            end
        end)
        TrackConnection(FlyConnection)
    end
    
    local function StopFlying()
        if FlyConnection then FlyConnection:Disconnect(); FlyConnection = nil end
        local Character = LocalPlayer.Character
        if Character then
            local Root = Character:FindFirstChild("HumanoidRootPart")
            local Humanoid = Character:FindFirstChildOfClass("Humanoid")
            if Root then
                local oldBV = Root:FindFirstChild("DScript_FlyBV")
                local oldBG = Root:FindFirstChild("DScript_FlyBG")
                if oldBV then oldBV:Destroy() end
                if oldBG then oldBG:Destroy() end
            end
            if Humanoid then Humanoid.PlatformStand = false end
        end
    end
    
    LocalPlayer.CharacterAdded:Connect(function()
        if FlyState.Active then
            task.wait(0.5)
            if FlyState.Active then StartFlying() end
        end
    end)
    
    TrackConnection(UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe or not FlyState.Active then return end
        local key = input.KeyCode
        if key == Enum.KeyCode.W then FlyState.ControlState.S = -1
        elseif key == Enum.KeyCode.S then FlyState.ControlState.W = 1
        elseif key == Enum.KeyCode.A then FlyState.ControlState.D = -1
        elseif key == Enum.KeyCode.D then FlyState.ControlState.A = 1
        elseif key == Enum.KeyCode.Space then FlyState.ControlState.Up = 1
        elseif key == Enum.KeyCode.LeftControl then FlyState.ControlState.Down = -1
        end
    end))
    
    TrackConnection(UserInputService.InputEnded:Connect(function(input)
        local key = input.KeyCode
        if key == Enum.KeyCode.W then FlyState.ControlState.S = 0
        elseif key == Enum.KeyCode.S then FlyState.ControlState.W = 0
        elseif key == Enum.KeyCode.A then FlyState.ControlState.D = 0
        elseif key == Enum.KeyCode.D then FlyState.ControlState.A = 0
        elseif key == Enum.KeyCode.Space then FlyState.ControlState.Up = 0
        elseif key == Enum.KeyCode.LeftControl then FlyState.ControlState.Down = 0
        end
    end))
    
    AddSectionHeader(p, "MOVEMENT HACKS")
    AddToggle(p, "FlyActive", "Enable Fly", false, function(state)
        FlyState.Active = state
        if state then StartFlying() else StopFlying() end
    end)
    
    AddSlider(p, "FlySpeed", "Fly Speed", 10, 250, 50, function(value)
        FlyState.Speed = value
    end)
    
    AddSectionHeader(p, "TELEPORT SLOTS")
    AddButton(p, "Teleport to Merchant", function() end)
    AddButton(p, "Teleport to My Garden", function() end)
end

