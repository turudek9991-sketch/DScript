-- 2. FUNGSI UNTUK MELAKUKAN SERVER HOPPING AMAN
local function ServerHop()
    print("[Hopper] Mendeteksi akun tim! Mencari server baru...")
    local HttpService = game:GetService("HttpService")
    local TeleportService = game:GetService("TeleportService")
    local LocalPlayer = game:GetService("Players").LocalPlayer
    
    -- Mengambil daftar server publik acak dari API Roblox
    local success, result = pcall(function()
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and result and result.data then
        for _, server in ipairs(result.data) do
            -- Cari server yang masih muat dan bukan server saat ini
            if server.id ~= game.JobId and server.playing < server.maxPlayers then
                pcall(function()
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                end)
                task.wait(2) -- Jeda penahan agar tidak spamming jika proses teleport delay
            end
        end
    else
        -- Cadangan jika API Roblox sedang lag, gunakan sistem Hop standar
        pcall(function()
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        end)
    end
end

-- 3. LOGIKA DETEKSI AKUN DI DALAM SERVER
local function PeriksaServer()
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    
    -- Menunggu sampai semua player selesai loading data dasarnya
    task.wait(3) 
    
    for _, player in ipairs(Players:GetPlayers()) do
        -- Pastikan script TIDAK mendeteksi dirinya sendiri
        if player ~= LocalPlayer then
            -- Mencocokkan nama player di server dengan daftar list kita
            for _, targetName in ipairs(MyAccountList) do
                if player.Name:lower() == targetName:lower() then
                    print("[Hopper] AWAS! Akun " .. player.Name .. " ditemukan di server ini.")
                    ServerHop()
                    return true -- Menghentikan pengecekan karena sudah pasti Hop
                end
            end
        end
    end
    print("[Hopper] Server Aman! Tidak ada akun tim lain di sini. Melanjutkan farm...")
    return false
end

-- 4. JALANKAN DETEKSI OTOMATIS SAAT MASUK GAME
task.spawn(function()
    -- Beri jeda 5 detik saat baru masuk game agar data server termuat sempurna
    task.wait(5)
    
    local terdeteksi = PeriksaServer()
    
    -- Jalankan pengintai background jika ada player baru yang menyusul masuk server
    if not terdeteksi then
        game:GetService("Players").PlayerAdded:Connect(function(newPlayer)
            for _, targetName in ipairs(MyAccountList) do
                if newPlayer.Name:lower() == targetName:lower() then
                    ServerHop()
                end
            end
        end)
    end
end)
