-- ====== SETTINGS (PERFORMANCE & CONFIG CORE) ================
do
    local p = TabPages["Settings"]
    AddSectionHeader(p, "PERFORMANCE")
    
    -- Feature: Reduce Lag
    AddToggle(p, "ReduceLag", "Reduce Lag", false, function(state)
        if state then
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            Lighting.GlobalShadows = false
            Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
            for _, v in ipairs(game:GetDescendants()) do
                if v:IsA("Part") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
                    v.Material = Enum.Material.SmoothPlastic
                    v.CastShadow = false
                elseif v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") then
                    v.Enabled = false
                end
            end
        else
            Lighting.GlobalShadows = true
            -- Mengembalikan ke default bawaan game jika dimatikan
            for _, v in ipairs(game:GetDescendants()) do
                if v:IsA("Part") or v:IsA("MeshPart") then
                    v.Material = Enum.Material.Plastic
                end
            end
        end
    end)
    
    -- Feature: White White Screen (Optimize CPU/RAM Engine)
    local ccEffect = Lighting:FindFirstChild("DScript_WhiteScreen")
    AddToggle(p, "WhiteScreen", "White White Screen", false, function(state)
        if state then
            if not ccEffect then
                ccEffect = Instance.new("ColorCorrectionEffect")
                ccEffect.Name = "DScript_WhiteScreen"
                ccEffect.Brightness = 1
                ccEffect.Contrast = 0
                ccEffect.Saturation = -1
                ccEffect.TintColor = Color3.fromRGB(255, 255, 255)
                ccEffect.Parent = Lighting
            end
            ccEffect.Enabled = true
            
            -- Membatasi render frame internal jika aplikasi di-minimize (mengurangi penggunaan hardware)
            if setfpscap then setfpscap(15) end
        else
            if ccEffect then ccEffect.Enabled = false end
            if setfpscap then setfpscap(60) end
        end
    end)
    
    AddSectionHeader(p, "CONFIGURATION")
    
    -- Action: Save Config
    AddButton(p, "Save Config", function()
        CreatePopupPrompt("SIMPAN KONFIGURASI", false, nil, function(configName)
            local fileName = "DScriptHUB_" .. configName .. ".json"
            local success, jsonStr = pcall(function()
                return game:GetService("HttpService"):JSONEncode(FeaturesState)
            end)
            if success and writefile then
                writefile(fileName, jsonStr)
                print("[DScriptHUB] Config '"..configName.."' berhasil disimpan!")
            else
                print("[DScriptHUB] Gagal menyimpan file config (Pastikan Executor mendukung writefile)")
            end
        end)
    end)
    
    -- Action: Load Config
    AddButton(p, "Load Config", function()
        if not listfiles then 
            print("[DScriptHUB] Executor kamu tidak mendukung pembacaan direktori file.")
            return 
        end
        
        local allFiles = listfiles("")
        local configFiles = {}
        for _, file in ipairs(allFiles) do
            if string.match(file, "^DScriptHUB_.*%.json$") or string.match(file, "DScriptHUB_") then
                local cleanName = string.gsub(file, "DScriptHUB_", "")
                cleanName = string.gsub(cleanName, "%.json", "")
                table.insert(configFiles, cleanName)
            end
        end
        
        if #configFiles == 0 then
            print("[DScriptHUB] Tidak ada konfigurasi tersimpan ditemukan.")
            return
        end
        
        CreatePopupPrompt("PILIH KONFIGURASI", true, configFiles, function(selectedConfig)
            local fileName = "DScriptHUB_" .. selectedConfig .. ".json"
            if readfile and isfile(fileName) then
                local data = readfile(fileName)
                local success, decoded = pcall(function() return game:GetService("HttpService"):JSONDecode(data) end)
                if success and decoded then
                    for k, v in pairs(decoded) do
                        if RegisteredToggles[k] then
                            RegisteredToggles[k].Set(v)
                        end
                    end
                    print("[DScriptHUB] Konfigurasi '" .. selectedConfig .. "' berhasil dimuat!")
                end
            end
        end)
    end)
    
    -- Action: Reset to Default
    AddButton(p, "Reset to Default", function()
        for k, _ in pairs(FeaturesState) do
            if RegisteredToggles[k] then
                if string.find(k, "Slider") then
                    RegisteredToggles[k].Set(k == "VisualSlider" and 50 or (k == "MiscSlider" and 16 or 1))
                else
                    RegisteredToggles[k].Set(false)
                end
            end
        end
        print("[DScriptHUB] Pengaturan dikembalikan ke awal!")
    end)
end

-- ============================================================
-- DRAG MAIN FRAME (Menggunakan RenderStepped Agar Sangat Halus)
-- ============================================================
do
    local dragging = false
    local dragInput, dragStart, startPos

    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    TitleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

