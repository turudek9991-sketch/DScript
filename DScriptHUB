-- ====== TAB: SETTINGS =======================================
do
    local p = TabPages["Settings"]
    AddSectionHeader(p, "PERFORMANCE")
    
    AddToggle(p, "ReduceLag", "Reduce Lag", false, function(state)
        if state then
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            Lighting.GlobalShadows = false
            for _, v in ipairs(game:GetDescendants()) do
                if v:IsA("Part") or v:IsA("MeshPart") then
                    v.Material = Enum.Material.SmoothPlastic
                    v.CastShadow = false
                elseif v:IsA("ParticleEmitter") or v:IsA("Smoke") then
                    v.Enabled = false
                end
            end
        else
            Lighting.GlobalShadows = true
        end
    end)
    
    local ccEffect = Lighting:FindFirstChild("DScript_WhiteScreen")
    AddToggle(p, "WhiteScreen", "White White Screen", false, function(state)
        if state then
            if not ccEffect then
                ccEffect = Instance.new("ColorCorrectionEffect")
                ccEffect.Name = "DScript_WhiteScreen"
                ccEffect.Brightness = 1
                ccEffect.TintColor = Color3.fromRGB(255, 255, 255)
                ccEffect.Parent = Lighting
            end
            ccEffect.Enabled = true
            if setfpscap then setfpscap(15) end
        else
            if ccEffect then ccEffect.Enabled = false end
            if setfpscap then setfpscap(60) end
        end
    end)
    
    AddSectionHeader(p, "CONFIGURATION")
    
    AddButton(p, "Save Config", function()
        CreatePopupPrompt("SIMPAN KONFIGURASI", false, nil, function(configName)
            local fileName = "DScriptHUB_Garden_" .. configName .. ".json"
            local success, jsonStr = pcall(function() return HttpService:JSONEncode(FeaturesState) end)
            if success and writefile then
                writefile(fileName, jsonStr)
                print("[DScriptHUB] Saved: " .. configName)
            end
        end)
    end)
    
    AddButton(p, "Load Config", function()
        if not listfiles then return end
        local allFiles = listfiles("")
        local configFiles = {}
        for _, file in ipairs(allFiles) do
            if string.match(file, "DScriptHUB_Garden_") then
                local name = string.gsub(file, "DScriptHUB_Garden_", ""):gsub("%.json", "")
                table.insert(configFiles, name)
            end
        end
        
        if #configFiles == 0 then return end
        
        CreatePopupPrompt("PILIH KONFIGURASI", true, configFiles, function(selectedConfig)
            local fileName = "DScriptHUB_Garden_" .. selectedConfig .. ".json"
            if readfile and isfile(fileName) then
                local data = readfile(fileName)
                local success, decoded = pcall(function() return HttpService:JSONDecode(data) end)
                if success and decoded then
                    for k, v in pairs(decoded) do
                        if RegisteredToggles[k] then RegisteredToggles[k].Set(v) end
                    end
                end
            end
        end)
    end)
    
    AddButton(p, "Reset to Default", function()
        for k, _ in pairs(FeaturesState) do
            if RegisteredToggles[k] then
                if string.find(k, "Slider") then
                    RegisteredToggles[k].Set(k == "MainSlider" and 25 or 1)
                elseif k == "DiscordWebhookURL" then
                    RegisteredToggles[k].Set("")
                else
                    RegisteredToggles[k].Set(false)
                end
            end
        end
    end)
end

-- ============================================================
-- SMOOTH DRAGGING CORE INTERFACE
-- ============================================================
do
    local dragging = false
    local dragInput, dragStart, startPos

    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    TitleBar.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

