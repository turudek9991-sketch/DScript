local function ProsesSikatItem(item)
    -- Amankan part koordinat target secepat mungkin
    local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart") or item.PrimaryPart
    if not targetPart then return end
    
    local namaKecil = item.Name:lower()
    
    -- Ambil ProximityPrompt secara instan tanpa antrean thread
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    local promptText = prompt and prompt.ObjectText:lower() or ""
    
    -- SISTEM DETEKSI KASTA BENIH GLOBAL (Membaca Nama Model & Teks Proximity UI)
    local IsEventSeed = false
    if string.find(namaKecil, "gold") or string.find(namaKecil, "rainbow") or 
       string.find(promptText, "gold") or string.find(promptText, "rainbow") or string.find(promptText, "claim") then
        IsEventSeed = true
    end
    
    -- Saklar Validasi Berdasarkan Menu GUI Executor
    if IsEventSeed and not Config.AutoSeedEvent then return end 
    if not IsEventSeed and not Config.AutoNormalSeed then return end 
    
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    
    if root then
        -- EXECUTION: Pindahkan CFrame Karakter Menabrak Objek Langsung
        root.CFrame = targetPart.CFrame
        
        -- INJECTION: Eksekusi bypass fungsi ambil di milidetik yang sama
        if prompt then
            AmbilPromptKilat(prompt)
        end
    end
end

