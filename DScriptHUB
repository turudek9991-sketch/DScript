local function CreatePopupPrompt(titleText, isDropdown, listOptions, callback)
    local Overlay = Instance.new("Frame")
    Overlay.Size = UDim2.new(1, 0, 1, 0)
    Overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Overlay.BackgroundTransparency = 0.6
    Overlay.ZIndex = 100
    Overlay.Parent = ScreenGui

    local PopFrame = Instance.new("Frame")
    PopFrame.Size = UDim2.new(0, 320, 0, isDropdown and 220 or 160)
    PopFrame.Position = UDim2.new(0.5, -160, 0.5, -(PopFrame.Size.Y.Offset/2))
    PopFrame.BackgroundColor3 = CONFIG.BgMain
    PopFrame.Parent = Overlay
    Instance.new("UICorner", PopFrame).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", PopFrame)
    stroke.Color = CONFIG.AccentColor

    local pTitle = Instance.new("TextLabel")
    pTitle.Size = UDim2.new(1, 0, 0, 35)
    pTitle.Text = titleText
    pTitle.TextColor3 = CONFIG.TextPrimary
    pTitle.Font = Enum.Font.GothamBold
    pTitle.TextSize = 13
    pTitle.BackgroundTransparency = 1
    pTitle.Parent = PopFrame

    local InteractionElement
    if not isDropdown then
        InteractionElement = Instance.new("TextBox")
        InteractionElement.Size = UDim2.new(1, -30, 0, 35)
        InteractionElement.Position = UDim2.new(0, 15, 0, 50)
        InteractionElement.BackgroundColor3 = CONFIG.BgItem
        InteractionElement.PlaceholderText = "Masukkan nama config..."
        InteractionElement.TextColor3 = CONFIG.TextPrimary
        InteractionElement.Text = ""
        InteractionElement.Font = Enum.Font.Gotham
        InteractionElement.TextSize = 12
        InteractionElement.Parent = PopFrame
        Instance.new("UICorner", InteractionElement).CornerRadius = UDim.new(0, 5)
    else
        InteractionElement = Instance.new("ScrollingFrame")
        InteractionElement.Size = UDim2.new(1, -30, 0, 100)
        InteractionElement.Position = UDim2.new(0, 15, 0, 50)
        InteractionElement.BackgroundColor3 = CONFIG.BgItem
        InteractionElement.ScrollBarThickness = 4
        InteractionElement.CanvasSize = UDim2.new(0, 0, 0, 0)
        InteractionElement.AutomaticCanvasSize = Enum.AutomaticSize.Y
        InteractionElement.Parent = PopFrame
        Instance.new("UICorner", InteractionElement).CornerRadius = UDim.new(0, 5)

        local listLayout = Instance.new("UIListLayout")
        listLayout.Padding = UDim.new(0, 2)
        listLayout.Parent = InteractionElement

        for _, optName in ipairs(listOptions) do
            local oBtn = Instance.new("TextButton")
            oBtn.Size = UDim2.new(1, 0, 0, 28)
            oBtn.BackgroundColor3 = CONFIG.BgContent
            oBtn.Text = optName
            oBtn.TextColor3 = CONFIG.TextPrimary
            oBtn.Font = Enum.Font.Gotham
            oBtn.TextSize = 11
            oBtn.Parent = InteractionElement
            Instance.new("UICorner", oBtn).CornerRadius = UDim.new(0, 4)

            oBtn.MouseButton1Click:Connect(function()
                Overlay:Destroy()
                if callback then callback(optName) end
            end)
        end
    end

    local BtnContainer = Instance.new("Frame")
    BtnContainer.Size = UDim2.new(1, -30, 0, 35)
    BtnContainer.Position = UDim2.new(0, 15, 1, -45)
    BtnContainer.BackgroundTransparency = 1
    BtnContainer.Parent = PopFrame

    local Cancel = Instance.new("TextButton")
    Cancel.Size = UDim2.new(0.48, 0, 1, 0)
    Cancel.BackgroundColor3 = CONFIG.BgItem
    Cancel.Text = "Batal"
    Cancel.TextColor3 = CONFIG.TextSecondary
    Cancel.Font = Enum.Font.Gotham
    Cancel.TextSize = 12
    Cancel.Parent = BtnContainer
    Instance.new("UICorner", Cancel).CornerRadius = UDim.new(0, 5)
    Cancel.MouseButton1Click:Connect(function() Overlay:Destroy() end)

    if not isDropdown then
        local Confirm = Instance.new("TextButton")
        Confirm.Size = UDim2.new(0.48, 0, 1, 0)
        Confirm.Position = UDim2.new(0.52, 0, 0, 0)
        Confirm.BackgroundColor3 = CONFIG.AccentColor
        Confirm.Text = "Konfirmasi"
        Confirm.TextColor3 = Color3.fromRGB(255, 255, 255)
        Confirm.Font = Enum.Font.GothamBold
        Confirm.TextSize = 12
        Confirm.Parent = BtnContainer
        Instance.new("UICorner", Confirm).CornerRadius = UDim.new(0, 5)

        Confirm.MouseButton1Click:Connect(function()
            local text = InteractionElement.Text
            Overlay:Destroy()
            if callback and text ~= "" then callback(text) end
        end)
    end
end

