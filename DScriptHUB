local function ServerHop()
    StatusLabel.Text      = "Status: HOPPING SERVER..."
    StatusLabel.TextColor3 = Color3.fromRGB(231, 76, 60)
    local ok, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(
            "https://games.roblox.com/v1/games/" .. game.PlaceId ..
            "/servers/Public?sortOrder=Asc&limit=100"))
    end)
    if ok and result and result.data then
        for _, server in ipairs(result.data) do
            if server.id ~= game.JobId and server.playing < server.maxPlayers then
                pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer) end)
                task.wait(0.5)
            end
        end
    else
        pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
    end
end

task.spawn(function()
    while TimeLeft > 0 do
        task.wait(1)
        TimeLeft -= 1
        TimerLabel.Text = string.format("Server Hop In: %dm %02ds",
            math.floor(TimeLeft/60), TimeLeft % 60)
    end
    ServerHop()
end)

-- ============================================================
-- [CORE] FIRE PROXIMITY PROMPT — SEMUA METHOD
-- ============================================================
local function AmbilPromptInstan(itemObject)
    local prompts = {}
    for _, v in ipairs(itemObject:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            table.insert(prompts, v)
        end
    end
    if #prompts == 0 then return end

    local sp = GetSpeed()

    for _, prompt in ipairs(prompts) do
        prompt.HoldDuration         = 0
        prompt.MaxActivationDistance = 9999

        task.spawn(function()
            -- Method 1: executor native (tercepat)
            if fireproximityprompt then
                pcall(fireproximityprompt, prompt)
            end

            -- Method 2: InputHold
            pcall(function()
                prompt:InputHoldBegin()
                task.wait(0.005)
                prompt:InputHoldEnd()
            end)

            -- Method 3: Retry setelah PromptRetry detik
            task.wait(sp.PromptRetry)
            if fireproximityprompt then
                pcall(fireproximityprompt, prompt)
            end

            -- Method 4: Retry ketiga (hanya turbo/instant yang retry cepat)
            task.wait(sp.PromptRetry)
            if fireproximityprompt then
                pcall(fireproximityprompt, prompt)
            end
        end)
    end
end

-- ============================================================
-- [CORE] PROSES ITEM — PAKAI SPEED PROFILE
-- ============================================================
local function ProsesSikatItem(item)
    if not item or not item.Parent then return end

    local sp       = GetSpeed()
    local namaKecil = item.Name:lower()
    local promptText = ""

    -- Tunggu prompt muncul sesuai PromptWait dari speed profile
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then
        local waited = 0
        repeat
            task.wait(0.03)
            waited += 0.03
            prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
        until prompt or waited >= sp.PromptWait
    end

    if prompt then promptText = prompt.ObjectText:lower() end

    -- Deteksi jenis seed
    local IsEventSeed =
        string.find(namaKecil,  "gold")    or string.find(namaKecil,  "rainbow") or
        string.find(namaKecil,  "event")   or string.find(promptText,  "gold")   or
        string.find(promptText, "rainbow") or string.find(promptText,  "claim")

    if IsEventSeed and not Config.AutoSeedEvent  then return end
    if not IsEventSeed and not Config.AutoNormalSeed then return end

    local character = LocalPlayer.Character
    local root      = character and character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local targetPart = (item:IsA("BasePart") and item)
        or item:FindFirstChildWhichIsA("BasePart", true)
        or item.PrimaryPart
    if not targetPart then return end

    -- Status UI
    if IsEventSeed then
        StatusLabel.Text       = "Status: SNIPING EVENT SEED! 🔥"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 140, 0)
    else
        StatusLabel.Text       = "Status: SNIPING NORMAL SEED"
        StatusLabel.TextColor3 = Color3.fromRGB(241, 196, 15)
    end

    -- Teleport ke atas target
    root.CFrame = targetPart.CFrame * CFrame.new(0, 2, 0)

    -- Tunggu server acknowledge posisi (dikontrol SpeedProfile)
    if sp.TeleportWait > 0 then task.wait(sp.TeleportWait) end

    if not item or not item.Parent then
        StatusLabel.Text       = "Status: SNIPING ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(46, 204, 113)
        return
    end

    AmbilPromptInstan(item)

    task.wait(0.1)
    StatusLabel.Text       = "Status: SNIPING ACTIVE"
    StatusLabel.TextColor3 = Color3.fromRGB(46, 204, 113)
end

-- ============================================================
-- [MONITOR] MULTI-FOLDER WATCHER
-- ============================================================
local DroppedItems  = workspace:WaitForChild("DroppedItems")
local MapFolder     = workspace:WaitForChild("Map")
local SeedPackClient = MapFolder:WaitForChild("SeedPackSpawnClient")
local SeedPackServer = MapFolder:WaitForChild("SeedPackSpawnServerLocations")

local function DaftarkanFolder(folder)
    for _, item in ipairs(folder:GetChildren()) do
        task.spawn(ProsesSikatItem, item)
    end
    folder.ChildAdded:Connect(function(newItem)
        local sp = GetSpeed()
        if sp.ChildWait > 0 then task.wait(sp.ChildWait) end
        task.spawn(ProsesSikatItem, newItem)
    end)
end

DaftarkanFolder(DroppedItems)
DaftarkanFolder(SeedPackClient)
DaftarkanFolder(SeedPackServer)
