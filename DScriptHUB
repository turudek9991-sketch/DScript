-- Fungsi buat tombol title bar
local function MakeTitleBtn(symbol, offsetX, color)
    local btn = Instance.new("TextButton")
    btn.Size              = UDim2.new(0, 26, 0, 26)
    btn.Position          = UDim2.new(1, offsetX, 0.5, -13)
    btn.BackgroundColor3  = Color3.fromRGB(38, 38, 46)
    btn.BorderSizePixel   = 0
    btn.Text              = symbol
    btn.TextColor3        = color or CONFIG.TextSecondary
    btn.TextSize          = 13
    btn.Font              = Enum.Font.GothamBold
    btn.ZIndex            = 15   -- ZIndex paling atas supaya selalu bisa diklik
    btn.Parent            = TitleBar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)

    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(38, 38, 46)
    end)
    return btn
end

