local function AddSlider(parent, configKey, labelText, minVal, maxVal, defaultVal, callback)
    minVal     = minVal or 0
    maxVal     = maxVal or 100
    FeaturesState[configKey] = math.clamp(defaultVal or minVal, minVal, maxVal)

    local wrapper = Instance.new("Frame")
    wrapper.Size             = UDim2.new(1, 0, 0, 54)
    wrapper.BackgroundColor3 = CONFIG.BgItem
    wrapper.BorderSizePixel  = 0
    wrapper.ZIndex           = 8
    wrapper.Parent           = parent
    Instance.new("UICorner", wrapper).CornerRadius = UDim.new(0, 7)

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1, -64, 0, 22)
    lbl.Position           = UDim2.new(0, 14, 0, 6)
    lbl.BackgroundTransparency = 1
    lbl.Text               = labelText
    lbl.TextColor3         = CONFIG.TextPrimary
    lbl.TextSize           = 12
    lbl.Font               = Enum.Font.Gotham
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.ZIndex             = 9
    lbl.Parent             = wrapper

    local valLbl = Instance.new("TextLabel")
    valLbl.Size               = UDim2.new(0, 50, 0, 22)
    valLbl.Position           = UDim2.new(1, -60, 0, 6)
    valLbl.BackgroundTransparency = 1
    valLbl.Text               = tostring(FeaturesState[configKey])
    valLbl.TextColor3         = CONFIG.AccentColor
    valLbl.TextSize           = 12
    valLbl.Font               = Enum.Font.GothamBold
    valLbl.TextXAlignment     = Enum.TextXAlignment.Right
    valLbl.ZIndex             = 9
    valLbl.Parent             = wrapper

    local track = Instance.new("Frame")
    track.Size             = UDim2.new(1, -28, 0, 4)
    track.Position         = UDim2.new(0, 14, 0, 36)
    track.BackgroundColor3 = CONFIG.SliderTrack
    track.BorderSizePixel  = 0
    track.ZIndex           = 9
    track.Parent           = wrapper
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.BackgroundColor3 = CONFIG.AccentColor
    fill.BorderSizePixel  = 0
    fill.ZIndex           = 10
    fill.Parent           = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local function updateSliderVisual()
        local ratio = (FeaturesState[configKey] - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(ratio, 0, 1, 0)
        valLbl.Text = tostring(FeaturesState[configKey])
    end
    updateSliderVisual()

    local hitbox = Instance.new("TextButton")
    hitbox.Size               = UDim2.new(1, 0, 0, 22)
    hitbox.Position           = UDim2.new(0, 0, 0, 28)
    hitbox.BackgroundTransparency = 1
    hitbox.Text               = ""
    hitbox.ZIndex             = 11
    hitbox.Parent             = wrapper

    local dragging = false
    hitbox.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    RunService.Heartbeat:Connect(function()
        if not dragging then return end
        local mX    = UserInputService:GetMouseLocation().X
        local aPos  = track.AbsolutePosition.X
        local aSize = track.AbsoluteSize.X
        local r     = math.clamp((mX - aPos) / aSize, 0, 1)
        FeaturesState[configKey] = math.floor(minVal + r * (maxVal - minVal))
        updateSliderVisual()
        if callback then callback(FeaturesState[configKey]) end
    end)

    RegisteredToggles[configKey] = {
        Set = function(newVal)
            FeaturesState[configKey] = math.clamp(newVal, minVal, maxVal)
            updateSliderVisual()
            if callback then callback(FeaturesState[configKey]) end
        end
    }
    return wrapper
end

