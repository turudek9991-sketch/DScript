-- Janitor untuk mencatat koneksi agar tidak dobel saat re-execute
local JanitorConnections = {}
local function TrackConnection(conn)
    table.insert(JanitorConnections, conn)
    return conn
end

_G.DScriptHUBCleanup = function()
    for _, conn in ipairs(JanitorConnections) do
        if conn and conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(JanitorConnections)
    _G.DScriptHUBCleanup = nil
    print("[DScriptHUB] Pembersihan total berhasil dilakukan!")
end

