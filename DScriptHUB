local function AddToggle(parent, configKey, labelText, defaultVal, callback)
    FeaturesState[configKey] = defaultVal
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, 0, 0, 40)
    row.BackgroundColor3 = CONFIG.BgItem
    row.Parent           = parent
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 7)

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1, -60, 1, 0)
    lbl.Position           = UDim2.new(0, 14, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text               = labelText
    lbl.TextColor3         = CONFIG.TextPrimary
    lbl.Font               = Enum.Font.Gotham
    lbl.TextSize           = 12
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.Parent             = row

    local toggleBg = Instance.new("Frame")
    toggleBg.Size             = UDim2.new(0, 38, 0, 20)
    toggleBg.Position         = UDim2.new(1, -50, 0.5, -10)
    toggleBg.BackgroundColor3 = FeaturesState[configKey] and CONFIG.ToggleOn or CONFIG.ToggleOff
    toggleBg.Parent           = row
    Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 14, 0, 14)
    knob.Position         = FeaturesState[configKey] and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent           = toggleBg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton")
    btn.Size               = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text               = ""
    btn.Parent             = row

    local function updateVisuals(anim)
        local duration = anim and 0.15 or 0
        TweenService:Create(toggleBg, TweenInfo.new(duration), {BackgroundColor3 = FeaturesState[configKey] and CONFIG.ToggleOn or CONFIG.ToggleOff}):Play()
        TweenService:Create(knob, TweenInfo.new(duration), {Position = FeaturesState[configKey] and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)}):Play()
    end

    btn.MouseButton1Click:Connect(function()
        FeaturesState[configKey] = not FeaturesState[configKey]
        updateVisuals(true)
        if callback then callback(FeaturesState[configKey]) end
    end)
    btn.MouseEnter:Connect(function() TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = CONFIG.BgItemHover}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = CONFIG.BgItem}):Play() end)

    RegisteredToggles[configKey] = {
        Set = function(newVal)
            FeaturesState[configKey] = newVal
            updateVisuals(false)
            if callback then callback(newVal) end
        end
    }
    return row
end

