-- Pembuat Komponen Toggle
local function BuatToggle(nama, urutanY, configKey)
    local defaultOn = Config[configKey]
    local CheckBtn = Instance.new("TextButton", MainFrame)
    CheckBtn.Size = UDim2.new(0, 105, 0, 22)
    CheckBtn.Position = UDim2.new(0, urutanY == 1 and 10 or 125, 0, 65)
    CheckBtn.BackgroundColor3 = defaultOn and Color3.fromRGB(35, 155, 86) or Color3.fromRGB(45, 45, 45)
    CheckBtn.Text = nama .. (defaultOn and ": ON" or ": OFF")
    CheckBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    CheckBtn.Font = Enum.Font.GothamBold
    CheckBtn.TextSize = 10
    local BtnCorner = Instance.new("UICorner", CheckBtn)
    BtnCorner.CornerRadius = UDim.new(0, 4)
    
    CheckBtn.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        local currentStatus = Config[configKey]
        
        CheckBtn.BackgroundColor3 = currentStatus and Color3.fromRGB(35, 155, 86) or Color3.fromRGB(45, 45, 45)
        CheckBtn.Text = nama .. (currentStatus and ": ON" or ": OFF")
        
        SaveConfig()
    end)
end

