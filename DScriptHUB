-- FUNGSI MODERATOR SWITCH OVAL (MENGAKOMODASI KLIK SAKLAR iOS)
-- ------------------------------------------------------------
local function BuatSwitchOval(namaText, urutanY, configKey)
    local YPos = 58 + (urutanY * 34)
    
    -- Label Nama Menu
    local Label = Instance.new("TextLabel", MainFrame)
    Label.Size = UDim2.new(0, 150, 0, 26)
    Label.Position = UDim2.new(0, 14, 0, YPos)
    Label.BackgroundTransparency = 1
    Label.Text = namaText
    Label.TextColor3 = Config[configKey] and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(140, 140, 140)
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Background Capsule Oval Slider
    local SwitchBg = Instance.new("TextButton", MainFrame)
    SwitchBg.Size = UDim2.new(0, 44, 0, 22)
    SwitchBg.Position = UDim2.new(0, 200, 0, YPos + 2)
    SwitchBg.Text = ""
    SwitchBg.BackgroundColor3 = Config[configKey] and Color3.fromRGB(39, 174, 96) or Color3.fromRGB(40, 40, 40)
    local RoundBg = Instance.new("UICorner", SwitchBg)
    RoundBg.CornerRadius = UDim.new(1, 0)
    
    -- Tombol Bulat Putih di dalam Slider
    local Ball = Instance.new("Frame", SwitchBg)
    Ball.Size = UDim2.new(0, 16, 0, 16)
    Ball.Position = Config[configKey] and UDim2.new(0, 25, 0, 3) or UDim2.new(0, 3, 0, 3)
    Ball.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
    local RoundBall = Instance.new("UICorner", Ball)
    RoundBall.CornerRadius = UDim.new(1, 0)
    
    SwitchBg.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        local state = Config[configKey]
        SaveConfig()
        
        -- Animasi Transisi Halus
        local targetColor = state and Color3.fromRGB(39, 174, 96) or Color3.fromRGB(40, 40, 40)
        local targetPos = state and UDim2.new(0, 25, 0, 3) or UDim2.new(0, 3, 0, 3)
        
        TweenService:Create(SwitchBg, TweenInfo.new(0.15), {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(Ball, TweenInfo.new(0.15), {Position = targetPos}):Play()
        
        Label.Text = namaText
        Label.TextColor3 = state and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(140, 140, 140)
    end)
end

BuatSwitchOval("NORMAL SEED", 0, "AutoNormalSeed")
