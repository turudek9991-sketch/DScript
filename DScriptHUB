local function ServerHop()
    StatusLabel.Text = "Status: HOPPING SERVER..."
    StatusLabel.TextColor3 = Color3.fromRGB(231, 76, 60)
    local success, result = pcall(function()
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if success and result and result.data then
        for _, server in ipairs(result.data) do
            if server.id ~= game.JobId and server.playing < server.maxPlayers then
                pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer) end)
                task.wait(0.5)
            end
        end
    else
        pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
    end
end

task.spawn(function()
    while TimeLeft > 0 do
        task.wait(1)
        TimeLeft = TimeLeft - 1
        local minutes = math.floor(TimeLeft / 60)
        local seconds = TimeLeft % 60
        TimerLabel.Text = string.format("Server Hop In: %dm %02ds", minutes, seconds)
    end
    ServerHop()
end)

-- ============================================================
-- [CORE LOGIC] TOTAL RE-FILTERING SYSTEM VIA MULTI-CHECK DETECTOR
-- ============================================================
local function AmbilPromptInstan(itemObject)
    local prompt = itemObject:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        prompt.HoldDuration = 0
        task.spawn(function()
            prompt:InputHoldBegin()
            task.wait(0.01)
            prompt:InputHoldEnd()
            if fireproximityprompt then fireproximityprompt(prompt) end
        end)
    end
end

local function ProsesSikatItem(item)
    local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart") or item.PrimaryPart
    if not targetPart then return end
    
    -- AMBIL SELURUH INFORMASI STRING UNTUK MENGHINDARI BUG DETEKSI
    local namaKecil = item.Name:lower()
    local promptText = ""
    
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        promptText = prompt.ObjectText:lower() -- Membaca teks "Gold Seed" atau "Rainbow Seed" dari interaksi UI game
    end
    
    -- DETEKSI MUTLAK: Periksa nama objek DAN teks prompt interaksinya
    local IsEventSeed = false
    if string.find(namaKecil, "gold") or string.find(namaKecil, "rainbow") or 
       string.find(promptText, "gold") or string.find(promptText, "rainbow") or string.find(promptText, "claim") then
        IsEventSeed = true
    end
    
    -- SAKLAR FILTER TOGGLE CONFIG
    if IsEventSeed and not Config.AutoSeedEvent then return end 
    if not IsEventSeed and not Config.AutoNormalSeed then return end 
    
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    
    if root then
        StatusLabel.Text = IsEventSeed and "Status: SNIPING EVENT SEED! 🔥" or "Status: SNIPING NORMAL SEED"
        StatusLabel.TextColor3 = IsEventSeed and Color3.fromRGB(255, 140, 0) or Color3.fromRGB(241, 196, 15)
        
        -- Eksekusi Teleportasi Tepat di Titik Koordinat Barang
        root.CFrame = targetPart.CFrame * CFrame.new(0, 1, 0)
        task.wait(IsEventSeed and 0.15 or 0.08)
        
        -- Eksekusi Bypass Ambil Prompt Instan
        AmbilPromptInstan(item)
        
        task.wait(0.05)
        StatusLabel.Text = "Status: SNIPING ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(46, 204, 113)
    end
end

