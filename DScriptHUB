local function SwitchTab(tabName)
    for name, page in pairs(TabPages) do page.Visible = (name == tabName) end
    for name, btn in pairs(TabButtons) do
        if name == tabName then
            btn.BackgroundTransparency = 0
            btn.BackgroundColor3       = CONFIG.BgTabActive
            btn.TextColor3             = CONFIG.TextPrimary
        else
            btn.BackgroundTransparency = 1
            btn.TextColor3             = CONFIG.TextSecondary
        end
    end
    ActiveTab = tabName
end

for i, tab in ipairs(TABS) do
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size                = UDim2.new(1, 0, 0, 34)
    tabBtn.BackgroundTransparency = 1
    tabBtn.BackgroundColor3    = CONFIG.BgTabActive
    tabBtn.BorderSizePixel     = 0
    tabBtn.Text                = string.format("  %s  %s", tab.Icon, tab.Name)
    tabBtn.TextColor3          = CONFIG.TextSecondary
    tabBtn.Font                = Enum.Font.Gotham
    tabBtn.TextXAlignment      = Enum.TextXAlignment.Left
    tabBtn.LayoutOrder         = i
    tabBtn.Parent              = TabList
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 6)

    local page = MakeContentFrame()
    TabPages[tab.Name]   = page
    TabButtons[tab.Name] = tabBtn

    tabBtn.MouseButton1Click:Connect(function() SwitchTab(tab.Name) end)
    tabBtn.MouseEnter:Connect(function()
        if ActiveTab ~= tab.Name then
            tabBtn.BackgroundTransparency = 0
            tabBtn.BackgroundColor3       = Color3.fromRGB(35, 42, 35)
        end
    end)
    tabBtn.MouseLeave:Connect(function() if ActiveTab ~= tab.Name then tabBtn.BackgroundTransparency = 1 end end)
end

SwitchTab(TABS[1].Name)

