    AutoDroppedItems = true,
    AutoSeedPackServer = true
}

local function LoadConfig()
    if isfile and readfile and isfile(ConfigFile) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigFile)) end)
        if success and type(data) == "table" then
            if data.AutoDroppedItems ~= nil then Config.AutoDroppedItems = data.AutoDroppedItems end
            if data.AutoSeedPackServer ~= nil then Config.AutoSeedPackServer = data.AutoSeedPackServer end
        end
    end
end

local function SaveConfig()
    if writefile then pcall(function() writefile(ConfigFile, HttpService:JSONEncode(Config)) end) end
end

